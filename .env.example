# OnGoal Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# LLM Provider Configuration
# ==========================================
# Choose your LLM provider: ollama (local or cloud), openrouter (free tier), anthropic (paid)
LLM_PROVIDER=ollama

# --- Ollama (local + cloud models) ---
# Local models run on your GPU. Cloud models (:cloud suffix) run on Ollama's servers.
# Cloud models require: ollama signin  (https://ollama.com account)
# List cloud models: https://ollama.com/search?c=cloud
# Run: ollama pull gemma4:31b-cloud
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b-cloud  # or qwen3.5:cloud, minimax-m2.7:cloud, glm-5.1:cloud, kimi-k2.5:cloud
OLLAMA_MAX_RETRIES=3                  # retry on 429/5xx errors
OLLAMA_RETRY_DELAY_MS=1000            # initial backoff in ms, doubles each retry

# --- OpenRouter (free tier available) ---
# Sign up at: https://openrouter.ai
# Free models: google/gemma-2-9b-it:free, meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# --- Anthropic Claude (paid) ---
# Sign up at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ==========================================
# Server Configuration (optional)
# ==========================================
# BACKEND_PORT=8000
# FRONTEND_PORT=8080
# CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ==========================================
# Development Settings (optional)
# ==========================================
# DEBUG=true
# LOG_LEVEL=info
